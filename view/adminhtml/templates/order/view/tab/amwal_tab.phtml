<!-- JavaScript: Collapse toggle & Update Order Status -->
<script>
require(['jquery', 'mage/translate'], function($, $t) {
    'use strict';

    // ---- Section collapse toggle ----
    $(document).on('click', '[data-amwal-toggle]', function(e) {
        e.preventDefault();
        var $section = $(this).closest('[data-amwal-section]');
        $section.toggleClass('amwal-section--collapsed');
    });

    // ---- Update Order Status ----
    <?php
    $amwalDataForJs = $block->getDecodedAmwalData();
    $jsConfig = [
        'orderId'      => $currentOrder ? $currentOrder->getIncrementId() : '',
        'amwalOrderId' => $amwalDataForJs['id'] ?? '',
        'refId'        => $amwalDataForJs['ref_id'] ?? '',
        'amwalStatus'  => $amwalDataForJs['status'] ?? '',
        'storeStatus'  => $storeStatus,
    ];
    ?>
    var config = <?= json_encode($jsConfig) ?>;

    // ---- Resend Webhook ----
    var resendWebhookUrl = <?= json_encode($block->getResendWebhookUrl()) ?>;

    $(document).on('click', '.amwal-resend-webhook-btn', function() {
        var $btn = $(this);
        var originalHtml = $btn.html();

        if (!confirm($t('Are you sure you want to resend the webhook for this transaction? This will re-trigger webhook processing.'))) {
            return;
        }

        $btn.prop('disabled', true).html(
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="amwal-spin"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> ' +
            $t('Resending...')
        );

        $.ajax({
            url: resendWebhookUrl,
            type: 'POST',
            dataType: 'json',
            data: {
                amwal_order_id: config.amwalOrderId,
                magento_order_id: config.orderId,
                form_key: window.FORM_KEY
            },
            success: function(data) {
                if (data.success) {
                    $btn.removeClass('amwal-btn--outline').addClass('amwal-btn--success');
                    $btn.html(
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> ' +
                        $t('Webhook Resent!')
                    );
                    setTimeout(function() {
                        location.reload();
                    }, 2000);
                } else {
                    alert(data.message || $t('Failed to resend webhook.'));
                    $btn.prop('disabled', false).html(originalHtml);
                }
            },
            error: function(xhr) {
                var msg = $t('An error occurred while resending the webhook.');
                try {
                    var resp = JSON.parse(xhr.responseText);
                    if (resp.message) msg = resp.message;
                } catch(e) {}
                alert(msg);
                $btn.prop('disabled', false).html(originalHtml);
            }
        });
    });

    // Bind handler if the button exists (PHP shouldShowUpdateButton() controls visibility)
    var failedStatuses = ['fail', 'failed', 'expired', 'cancelled'];
    var pendingStatuses = ['pending', 'pending_payment'];
    var shouldBind = (config.amwalStatus === 'success' && config.storeStatus !== 'processing')
        || (failedStatuses.indexOf(config.amwalStatus) !== -1 && pendingStatuses.indexOf(config.storeStatus) !== -1);

    if (shouldBind) {
        $(document).on('click', '.amwal-order-status-update', function() {
            var $btn = $(this);
            $btn.prop('disabled', true).text($t('Updating...'));

            fetch('/rest/V1/amwal/order/status', {
                method: 'POST',
                body: JSON.stringify({
                    order_id: config.orderId,
                    amwal_order_id: config.amwalOrderId,
                    ref_id: config.refId
                }),
                headers: {
                    'Content-type': 'application/json; charset=UTF-8'
                }
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.message) {
                    alert(data.message);
                }
                location.reload();
            })
            .catch(function() {
                alert($t('An error occurred while updating the order status.'));
                $btn.prop('disabled', false).text($t('Update Order Status'));
            });
        });
    }

    // ---- Support: Email button ----
    $(document).on('click', '#amwal-support-email-btn', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var subject = encodeURIComponent($(this).data('support-subject') || '');
        var body    = encodeURIComponent($(this).data('support-body') || '');
        var mailtoUrl = 'mailto:support@amwal.tech?subject=' + subject + '&body=' + body;
        window.location.href = mailtoUrl;
    });

    // ---- Support: Copy details button ----
    $(document).on('click', '#amwal-support-copy-btn', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var $btn = $(this);
        var bodyText = 'To: support@amwal.tech\nSubject: ' + ($('#amwal-support-email-btn').data('support-subject') || '') + '\n\n' + ($btn.data('support-body') || '');

        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(bodyText).then(function() {
                var origHtml = $btn.html();
                $btn.html('<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> ' + $t('Copied!'));
                setTimeout(function() { $btn.html(origHtml); }, 2000);
            });
        } else {
            // Fallback for older browsers
            var textarea = document.createElement('textarea');
            textarea.value = bodyText;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            var origHtml = $btn.html();
            $btn.html('<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> ' + $t('Copied!'));
            setTimeout(function() { $btn.html(origHtml); }, 2000);
        }
    });

    // ---- Webhook Payload Toggle ----
    $(document).on('click', '[data-amwal-payload-toggle]', function() {
        var $wrapper = $(this).closest('.amwal-payload-wrapper');
        $wrapper.toggleClass('amwal-payload-row--active');

        var isVisible = $wrapper.hasClass('amwal-payload-row--active');
        $(this).find('.amwal-payload-icon').css('transform', isVisible ? 'rotate(90deg)' : 'rotate(0deg)');
    });

    // ---- Webhook Payload Copy ----
    $(document).on('click', '[data-amwal-copy-payload]', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var $btn = $(this);
        var $pre = $btn.closest('.amwal-payload-content').find('.amwal-payload-pre');
        var payloadText = $pre.text();

        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(payloadText).then(function() {
                var originalHtml = $btn.html();
                $btn.addClass('amwal-payload-copy--success').html('<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied!');
                setTimeout(function() { $btn.removeClass('amwal-payload-copy--success').html(originalHtml); }, 2000);
            });
        }
    });
});
</script>
