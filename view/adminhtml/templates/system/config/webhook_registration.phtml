<script type="text/javascript">
    require(['jquery', 'mage/translate'], function($, $t) {
        $(document).ready(function() {
            $('#<?= $block->getHtmlId() ?>_button').click(function() {
                var $btn = $(this);
                var $result = $('#amwal-webhook-result');

                // Gather inputs
                var webhookUrl = document.querySelector('[name="groups[amwal_payments][groups][webhook][fields][endpoint_url][value]"]');
                var webhookEvents = $('input[name="groups[amwal][fields][webhook_events][value][]"]:checked').map(function() {
                    return this.value;
                }).get();
                var formKey = $('input[name="form_key"]').val();

                if (!webhookUrl || !webhookUrl.value) {
                    $result.html('<div class="message message-error">' + $t('Webhook URL could not be detected.') + '</div>').show();
                    return;
                }
                if (!webhookEvents.length) {
                    $result.html('<div class="message message-error">' + $t('Please select at least one webhook event.') + '</div>').show();
                    return;
                }

                // Loading state
                $btn.attr('disabled', true);
                $result.html('<div class="message message-notice">' + $t('Registering webhook, please wait…') + '</div>').show();

                $.ajax({
                    url: '<?= $block->getAjaxUrl() ?>',
                    type: 'POST',
                    dataType: 'json',
                    data: {
                        webhook_url: webhookUrl.value,
                        webhook_events: webhookEvents,
                        form_key: formKey
                    },
                    success: function(response) {
                        if (response.success) {
                            $result.html(
                                '<div class="message message-success">' +
                                $t('Webhook registered successfully! Reload the page to see updated status.') +
                                '</div>'
                            ).show();
                        } else {
                            $result.html(
                                '<div class="message message-error">' +
                                $t('Failed to register webhook: ') + response.message +
                                '</div>'
                            ).show();
                        }
                    },
                    error: function() {
                        $result.html(
                            '<div class="message message-error">' +
                            $t('An error occurred while registering the webhook. Please try again or check system logs.') +
                            '</div>'
                        ).show();
                    },
                    complete: function() {
                        $btn.attr('disabled', false);
                    }
                });
            });
        });
    });
</script>

